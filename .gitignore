# =========================================================
# Customer Churn ML Project
# Production .gitignore
# =========================================================

# ---------------------------------------------------------
# Python
# ---------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
*.whl

# ---------------------------------------------------------
# Virtual Environments
# ---------------------------------------------------------
.venv/
venv/
env/
ENV/

# ---------------------------------------------------------
# Environment Variables
# ---------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------
# IDE
# ---------------------------------------------------------
.vscode/
.idea/
*.code-workspace

# ---------------------------------------------------------
# Operating System Files
# ---------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ---------------------------------------------------------
# Jupyter
# ---------------------------------------------------------
.ipynb_checkpoints/

# ---------------------------------------------------------
# Logs
# ---------------------------------------------------------
logs/
*.log
log.csv

# ---------------------------------------------------------
# Python Testing
# ---------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/

# ---------------------------------------------------------
# Build
# ---------------------------------------------------------
build/
dist/
*.spec

# ---------------------------------------------------------
# MLflow
# ---------------------------------------------------------
mlruns/

# ---------------------------------------------------------
# Artifacts
# ---------------------------------------------------------
artifacts/

# ---------------------------------------------------------
# Datasets
# ---------------------------------------------------------
data/raw/
data/processed/

# ---------------------------------------------------------
# Temporary Files
# ---------------------------------------------------------
*.tmp
*.bak
*.swp

# ---------------------------------------------------------
# Model Checkpoints
# ---------------------------------------------------------
checkpoints/
models/
*.pkl
*.joblib
*.h5

# ---------------------------------------------------------
# Keep Serving Model
# ---------------------------------------------------------
!src/serving/model/
!src/serving/model/**

# ---------------------------------------------------------
# Docker
# ---------------------------------------------------------
docker-compose.override.yml

# ---------------------------------------------------------
# Miscellaneous
# ---------------------------------------------------------
*.zip
*.tar
*.gz
*.7z
